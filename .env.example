# Application
APP_NAME="Aiogram Bot Template"
APP_VERSION="0.1.0"
APP_ENVIRONMENT="local"
APP_TIMEZONE="Europe/Moscow"

# Aiogram bot
BOT_TOKEN=TOKEN             # Token for bot from @BotFather
PARSE_MODE="HTML"           # Default parse mode
DROP_PENDING_UPDATES=True
# LOG_CHAT=-1111111111        # chat to send error logs (Optional)
RATE_LIMIT=0.5              # throttling rate limit (anti-spam)
# ALLOWED_UPDATES=["message","callback_query","my_chat_member","chat_member"]
ADMINS=[111, 222]           # administrators ids
DEBUG_MODE=False

# Database settings
DB_USED="PostgreSQL"        # PostgreSQL by default; MySQL requires asyncmy dependency
DB_IP="localhost"
DB_PORT=5432
DB_USER=DB_USER
DB_PASSWORD=DB_PASSWORD
DB_NAME=DB_NAME
# DB_TEST_NAME=DB_TEST_NAME
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Redis settings
REDIS_USE=False             # Set True if you want to use Redis
REDIS_IP="localhost"
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# Health/readiness checks
HEALTHCHECK_TIMEOUT_SECONDS=3
